/* To learn more about this file see: https://angular.io/config/tsconfig. */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": []
  },
  "files": [
    "src/main.ts"
  ],
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*_test.ts",
    "src/**/testing/**/*",
    "src/test.ts",
    "src/app/components/shared/asset-picker/asset-picker.component.ts",
    "src/app/components/shared/undo-redo-controls/undo-redo-controls.component.ts",
    "src/app/directives/svg-text-scaler.directive.ts"
  ]
}
